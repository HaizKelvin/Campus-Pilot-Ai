rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper functions
    function isSignedIn() { return request.auth != null; }
    function isOwner(userId) { return isSignedIn() && request.auth.uid == userId; }
    function isValidId(id) { return id is string && id.size() <= 128; }

    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // User profiles and telemetry
    match /users/{userId} {
      allow get: if isOwner(userId);
      allow create: if isOwner(userId) 
        && request.resource.data.keys().hasAll(['profile'])
        && request.resource.data.profile.name is string;
      allow update: if isOwner(userId);
      
      // Chat subcollection
      match /chats/{chatId} {
        allow list, get: if isOwner(userId);
        allow create: if isOwner(userId) 
          && request.resource.data.keys().hasAll(['role', 'content', 'timestamp'])
          && request.resource.data.role in ['user', 'model'];
      }
    }
  }
}
